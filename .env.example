## Server
PORT=5000

## CORS
# Comma-separated list of allowed frontend origins (Netlify domains)
# Example: https://your-site.netlify.app,https://your-custom-domain.com
CORS_ORIGIN=

## Database
DATABASE_URL=

## Admin auth
ADMIN_EMAIL=admin@rkfprestice.cz
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=12h

# Choose ONE:
# 1) Plain password (simple, but less secure)
ADMIN_PASSWORD=
# 2) bcrypt hash (recommended). Generate with:
# node -e "require('bcrypt').hash('yourPassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH=

## Mail
MAIL_FROM="Farnost Přeštice" <no-reply@example.com>

# Where to send contact form messages (recommended: info@rkfprestice.cz)
CONTACT_TO=info@rkfprestice.cz

# Where to send reservation notifications (optional; by default goes to CONTACT_TO)
RESERVATIONS_TO=

# Option A: Gmail service (requires app password)
GMAIL_USER=
GMAIL_PASS=

# Option B: Custom SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
